# eBay API - קבל ב: https://developer.ebay.com
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_REDIRECT_URI=http://localhost:3001/api/ebay/callback
EBAY_ENV=sandbox

# Shopify - קבל ב: https://partners.shopify.com
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_REDIRECT_URI=http://localhost:3001/api/shopify/callback

# Amazon SP-API - קבל ב: https://sellercentral.amazon.com/apps/manage
AMAZON_CLIENT_ID=your_amazon_client_id
AMAZON_CLIENT_SECRET=your_amazon_client_secret
AMAZON_REDIRECT_URI=http://localhost:3001/api/amazon/callback
AMAZON_MARKETPLACE=A1F83G8C2ARO7P

# Etsy API v3 - קבל ב: https://www.etsy.com/developers/register
ETSY_CLIENT_ID=your_etsy_keystring
ETSY_REDIRECT_URI=http://localhost:3001/api/etsy/callback

# WooCommerce - Consumer Key/Secret נוצרים בלוח הניהול של WordPress
# WooCommerce → הגדרות → מתקדם → REST API → הוסף מפתח
# (אין צורך בסביבה - הפרטים מוזנים ישירות בממשק)

# App
PORT=3001
FRONTEND_URL=https://YOUR_VERCEL_URL.vercel.app
JWT_SECRET=replace-with-strong-random-secret-min-32-chars
SUPERADMIN_EMAIL=boaz65sa@gmail.com
SUPERADMIN_PASSWORD=Admin123!

# Railway – set DATA_DIR to a persistent volume path e.g. /data
DATA_DIR=/data
